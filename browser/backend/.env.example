# Browser Automation Agent — Environment Config
# Copy this to .env and fill in your API key

# ─────────────────────────────────────────────
# LLM Provider (via LiteLLM)
# ─────────────────────────────────────────────
# Pick ONE provider and set its key:

# Option 1: Google Gemini (default)
# GEMINI_API_KEY=your-gemini-api-key-here
# GOOGLE_API_KEY=your-google-api-key-here

# Option 2: OpenAI
# OPENAI_API_KEY=your-openai-api-key-here

# Option 3: Anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ─────────────────────────────────────────────
# Model Selection (LiteLLM format)
# ─────────────────────────────────────────────
# Use LiteLLM model string format: "provider/model-name"
# Examples:
#   gemini/gemini-2.0-flash
#   openai/gpt-4o
#   anthropic/claude-3-haiku-20240307

LLM_MODEL=gemini/gemini-2.5-flash

# ─────────────────────────────────────────────
# Agent Settings
# ─────────────────────────────────────────────
AGENT_MAX_STEPS=30
AGENT_HEADLESS=true

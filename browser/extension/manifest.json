{
    "manifest_version": 3,
    "name": "GHMC Browser Automation Assistant",
    "version": "1.0",
    "description": "AI-powered side panel assistant for browsing, form filling, and automation.",
    "permissions": [
        "sidePanel",
        "activeTab",
        "scripting",
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "<all_urls>",
        "http://localhost:8000/*",
        "http://localhost:8001/*",
        "http://127.0.0.1:8000/*",
        "http://127.0.0.1:8001/*"
    ],
    "background": {
        "service_worker": "background/background.js"
    },
    "action": {
        "default_title": "Open Assistant"
    },
    "side_panel": {
        "default_path": "side_panel/panel.html"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content_scripts/content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "options_ui": {
        "page": "popup/options.html",
        "open_in_tab": false
    }
}